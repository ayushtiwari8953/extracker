# ---- Server ----
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ---- Database ----
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/fintrack?retryWrites=true&w=majority

# ---- Auth ----
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=30d
JWT_RESET_EXPIRES_IN=30m

# ---- Email (optional, for reset emails) ----
EMAIL_FROM=FinTrack <no-reply@fintrack.app>
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ---- File upload ----
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=2
